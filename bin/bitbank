#!/usr/bin/env node
// bitbank CLI launcher.
// Resolves tsx via createRequire so it works whether installed locally,
// globally (npm i -g), or run via `npx`. Avoids the `--import tsx` CWD
// resolution pitfall by invoking tsx's CLI entry directly.
import { spawn } from "node:child_process";
import { createRequire } from "node:module";
import { dirname, resolve } from "node:path";
import { fileURLToPath } from "node:url";

const require = createRequire(import.meta.url);
const here = dirname(fileURLToPath(import.meta.url));
const entry = resolve(here, "..", "cli", "index.ts");
const tsxCli = require.resolve("tsx/cli");

const child = spawn(process.execPath, [tsxCli, entry, ...process.argv.slice(2)], {
  stdio: "inherit",
});
child.on("error", (err) => {
  process.stderr.write(`bitbank: failed to start tsx: ${err.message}\n`);
  process.exit(1);
});
child.on("exit", (code, signal) => {
  if (signal) process.kill(process.pid, signal);
  else process.exit(code ?? 0);
});
