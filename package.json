{
  "name": "bitbank-lab-cli",
  "version": "0.1.2",
  "description": "Experimental CLI & Agent Skills starter kit for bitbank — botters lab community edition. Market data, paper trading, account read, and Private API trading with safety guards.",
  "type": "module",
  "bin": {
    "bitbank": "bin/bitbank"
  },
  "files": [
    "bin/",
    "cli/*.ts",
    "cli/commands/",
    "cli/completion/",
    "cli/watch/",
    "skills/",
    "AGENTS.md",
    "CLAUDE.md",
    "CONTEXT.md",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "cli": "tsx cli/index.ts",
    "cli:env": "tsx --env-file=.env cli/index.ts",
    "test": "vitest",
    "lint": "biome check cli/",
    "lint:fix": "biome check --fix cli/",
    "format": "biome format --write cli/",
    "typecheck": "tsc --noEmit",
    "version": "node scripts/sync-version.mjs && git add .claude-plugin/plugin.json .cursor-plugin/plugin.json .codex-plugin/plugin.json gemini-extension.json"
  },
  "dependencies": {
    "pubnub": "^11.0.0",
    "socket.io-client": "^4.8.3",
    "tsx": "^4.19.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "@types/node": "^20.0.0",
    "@vitest/coverage-v8": "^4.1.7",
    "lefthook": "2.1.6",
    "typescript": "^5.7.0",
    "vitest": "^3.1.0"
  },
  "engines": {
    "node": ">=20"
  },
  "homepage": "https://github.com/tjackiet/bitbank-cli-skills",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tjackiet/bitbank-cli-skills.git"
  },
  "bugs": {
    "url": "https://github.com/tjackiet/bitbank-cli-skills/issues"
  },
  "keywords": [
    "bitbank",
    "cryptocurrency",
    "trading",
    "agent-skills",
    "cli",
    "paper-trading"
  ],
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT"
}
